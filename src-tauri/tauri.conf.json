{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vega",
  "version": "1.2.3",
  "identifier": "com.vega.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vega",
        "width": 800,
        "height": 600,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "resources": [
      "lib/*.dll"
    ],
    "android": {
      "versionCode": 4
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vega-org/vega-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCNEQxMTZDNUI4OTg1RjAKUldUd2hZbGJiQkZOYTYxY0R4VW5ydHdzSlZaZkNPeGx5RTVhR0tZTGxIR1NmYWM4UnRjd2JySlMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
